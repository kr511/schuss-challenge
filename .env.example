# Schussduell – Environment Variables
#
# Cloudflare Worker Variables
# Nicht-sensitive Werte: in wrangler.jsonc unter "vars" eintragen
# Sensitive Werte (Secrets): via "wrangler secret put <NAME>" setzen
#
# Lokale Entwicklung: Secrets in .dev.vars eintragen (wird von wrangler dev geladen)
# Vorlage: .dev.vars.example → .dev.vars kopieren und ausfüllen

# ── Supabase (Required) ──────────────────────────────────────────────────────

# Die Supabase-Projekt-URL (public, bereits in wrangler.jsonc gesetzt)
SUPABASE_URL=https://fknftkvozwfkcarldzms.supabase.co

# Der Supabase Service-Role-Key (Secret! nie committen)
# Supabase Dashboard → Settings → API → service_role
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Der Supabase JWT Secret (Secret! nie committen)
# Supabase Dashboard → Settings → API → JWT Secret
SUPABASE_JWT_SECRET=DEIN_JWT_SECRET_HIER

# ── Auth & CORS ──────────────────────────────────────────────────────────────

# "true" NUR lokal – erlaubt x-dev-user-id Header ohne JWT
# In production MUSS dieser Wert "false" sein
ALLOW_INSECURE_DEV_AUTH=false

# Komma-separierte Liste erlaubter Origins (zusätzlich zu den Defaults in api.ts)
# Defaults: schuss-challenge.eliaskummel.workers.dev, kr511.github.io, localhost:8787
ALLOWED_ORIGINS_CSV=

# ── Admin ────────────────────────────────────────────────────────────────────

# Komma-separierte Supabase User-IDs mit Zugriff auf /api/admin/*
ADMIN_USER_IDS=

# ── E-Mail (Optional) ────────────────────────────────────────────────────────

# SendGrid API Key für automatische Feedback-E-Mails (optional)
SENDGRID_API_KEY=

# Admin-E-Mail-Adresse für Benachrichtigungen (optional)
ADMIN_EMAIL=
